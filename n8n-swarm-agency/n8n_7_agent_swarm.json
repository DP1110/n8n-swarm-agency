    {
      "id": "5195fc34-5eb8-441c-b76f-295bc5c9decd",
      "name": "CEO (Synthesizer)",
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.9,
      "position": [
        1152,
        480
      ],
      "parameters": {
        "promptType": "define",
        "text": "=You are the CEO Synthesizer of a 7-agent AI engineering swarm. All 6 specialists have completed their analysis. Aggregated output:\n\n{{ $input.all().map(item => item.json.text || item.json.output || '').join('\\n\\n---\\n\\n') }}\n\nSynthesize into a MASTER PROJECT PROPOSAL with sections: 1) Executive Summary 2) Product Design 3) Technical Architecture 4) Security Assessment 5) QA Plan 6) Documentation Plan 7) Project Management 8) Cross-Cutting Concerns 9) Risks & Mitigations 10) Recommended Next Steps. Be comprehensive and board-ready. Use markdown.",
        "batching": {}
      },
      "executeOnce": true,
      "retryOnFail": true
    },
    {
      "id": "b44bad07-bb11-4fd4-b33d-bac437b7c61e",
      "name": "Format Report Output",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1504,
        480
      ],
      "parameters": {
        "language": "javaScript",
        "mode": "runOnceForEachItem",
        "jsCode": "const raw = $json.text || $json.output || '';\nconst codeBlocks = [];\nlet processedText = raw.replace(/```([\\w]*)?\\n?([\\s\\S]*?)```/g, (match, lang, code) => {\n  const id = `CODE_${codeBlocks.length}`;\n  codeBlocks.push({ id, lang: lang ? lang.trim() : 'text', code: code.trim() });\n  return `\\n\\n[${id}]\\n\\n`;\n});\nconst sections = [];\nconst lines = processedText.split('\\n');\nlet currentSection = null;\nlet currentBody = [];\nfor (const line of lines) {\n  const headingMatch = line.match(/^#{1,3}\\s+(.+)/);\n  if (headingMatch) {\n    if (currentSection) sections.push({ title: currentSection, body: currentBody.join('\\n').trim() });\n    currentSection = headingMatch[1].replace(/^\\d+\\.\\s*/, '').trim();\n    currentBody = [];\n  } else { if (currentSection) currentBody.push(line); }\n}\nif (currentSection) sections.push({ title: currentSection, body: currentBody.join('\\n').trim() });\nif (sections.length === 0) sections.push({ title: 'Master Project Proposal', body: processedText.trim() });\nreturn { json: { success: true, report: { title: 'Master Project Proposal - 7-Agent AI Swarm', generated_at: new Date().toISOString(), agent_count: 7, word_count: raw.split(/\\s+/).filter(Boolean).length, sections_count: sections.length, sections, code_blocks: codeBlocks, raw_markdown: raw } } };"
      }
    },
